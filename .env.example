# G-Brain Environment Configuration
# Copy this file to .env and update with your values

# =============================================================================
# APPLICATION
# =============================================================================

ENVIRONMENT=development
DEBUG=true
API_VERSION=0.1.0
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
LOG_LEVEL=DEBUG

# =============================================================================
# DATABASE - PostgreSQL
# =============================================================================

DATABASE_URL=postgresql+asyncpg://gbrain_user:gbrain_password@postgres:5432/gbrain
DATABASE_POOL_SIZE=20
DATABASE_POOL_RECYCLE=3600
DATABASE_ECHO=false

# =============================================================================
# GRAPH DATABASE - Neo4j
# =============================================================================

NEO4J_URI=neo4j://neo4j:gbrain_password@neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=gbrain_password

# =============================================================================
# CACHE - Redis
# =============================================================================

REDIS_URL=redis://:gbrain_password@redis:6379
REDIS_PASSWORD=gbrain_password
REDIS_DB=0

# =============================================================================
# VECTOR DATABASE - Qdrant
# =============================================================================

QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=gbrain_key

# =============================================================================
# OBJECT STORAGE - S3 / MinIO
# =============================================================================

AWS_ACCESS_KEY_ID=gbrain_admin
AWS_SECRET_ACCESS_KEY=gbrain_password
S3_ENDPOINT=http://minio:9000
S3_BUCKET=gbrain-documents
S3_REGION=us-east-1

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================

SECRET_KEY=dev-secret-key-change-in-production-to-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# OAuth/OIDC (Optional - for production)
# AUTH0_DOMAIN=your-tenant.auth0.com
# AUTH0_CLIENT_ID=your-client-id
# AUTH0_CLIENT_SECRET=your-client-secret

# =============================================================================
# CORS
# =============================================================================

CORS_ORIGINS=["http://localhost:3000","http://localhost:8000","http://127.0.0.1:3000","http://127.0.0.1:8000"]
CORS_CREDENTIALS=true

# =============================================================================
# RATE LIMITING
# =============================================================================

RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# =============================================================================
# LLM PROVIDERS
# =============================================================================

OPENAI_API_KEY=sk-your-key-here
OPENAI_ORG_ID=

ANTHROPIC_API_KEY=sk-ant-your-key-here

# =============================================================================
# CELERY / TASK QUEUE
# =============================================================================

CELERY_BROKER_URL=redis://:gbrain_password@redis:6379/0
CELERY_RESULT_BACKEND=redis://:gbrain_password@redis:6379/0
CELERY_TASK_TIME_LIMIT=3600

# =============================================================================
# OBSERVABILITY
# =============================================================================

ENABLE_TRACING=false
ENABLE_METRICS=false
JAEGER_AGENT_HOST=localhost
JAEGER_AGENT_PORT=6831

# =============================================================================
# FEATURES
# =============================================================================

ENABLE_SKILL_EXTRACTION=true
ENABLE_GRAPH_INFERENCE=true
ENABLE_AGENT_EXECUTION=true
ENABLE_APPROVALS=true

# =============================================================================
# CONSTRAINTS
# =============================================================================

MAX_DOCUMENT_SIZE_MB=100
MAX_CHUNK_SIZE=1000
MAX_CONCURRENT_INGESTIONS=10
MAX_SKILL_EXECUTION_TIME_SECONDS=300
